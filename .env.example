OPENAI_MODEL=gpt-4.1-mini

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_READING_BUCKET=reading-images

# Optional payment mode for frontend ("test" | "live")
NEXT_PUBLIC_PAYMENT_MODE=test

# Stripe (used by existing checkout route)
STRIPE_SECRET_KEY=
